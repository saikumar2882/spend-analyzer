<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup / transfer rules for Android 12 (API 31)+.
   The canonical copy of all financial data lives in Firestore (users/{userId}/spends...) and
   re-syncs on reinstall, so the local Room DB and AI preferences are excluded from off-device
   backup and device-to-device transfer to avoid exporting personal spend data.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="spend_database" />
        <exclude domain="database" path="spend_database-wal" />
        <exclude domain="database" path="spend_database-shm" />
        <exclude domain="file" path="datastore/ai_preferences.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="spend_database" />
        <exclude domain="database" path="spend_database-wal" />
        <exclude domain="database" path="spend_database-shm" />
        <exclude domain="file" path="datastore/ai_preferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
