<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto Backup rules for devices older than API 31.
   Exclude the local financial database and AI preferences from cloud backup; they re-sync from
   Firestore on reinstall. See data_extraction_rules.xml for API 31+.
-->
<full-backup-content>
    <exclude domain="database" path="spend_database" />
    <exclude domain="database" path="spend_database-wal" />
    <exclude domain="database" path="spend_database-shm" />
    <exclude domain="file" path="datastore/ai_preferences.preferences_pb" />
</full-backup-content>
